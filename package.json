{
  "name": "gfa",
  "module": "src/gfa.tsx",
  "bin": {
    "gfa": "./dist/gfa"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "dev": "tsx src/gfa.tsx",
    "compile": "node ./scripts/build.mjs",
    "link": "chmod +x dist/gfa",
    "build": "run-s lint clean compile link",
    "distribute": "cp dist/gfa ~/bin",
    "deploy": "run-s build distribute",
    "lint": "run-s lint:format lint:ts lint:tsc",
    "lint:ts": "eslint .",
    "lint:tsc": "tsc -p tsconfig.json",
    "lint:format": "prettier -c ./src",
    "lint:formatfix": "prettier -w ./src"
  },
  "dependencies": {
    "ink": "^6.5.0",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "20.19.39",
    "@types/react": "^19.2.4",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "esbuild": "0.28.0",
    "eslint": "10.2.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "react-devtools-core": "^6.1.5",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1"
  }
}

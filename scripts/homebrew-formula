#!/usr/bin/env bash
set -euo pipefail

repo="kwo/gfa"
script_name="scripts/homebrew-formula"
tag=""

usage() {
  cat >&2 <<EOF
Usage: $script_name [--tag vX.Y.Z]

Print a ready-to-commit Homebrew formula for gfa to stdout.

Options:
  --tag <tag>   Use a specific GitHub release tag instead of the latest stable release
  -h, --help    Show this help message
EOF
}

die() {
  echo "$script_name: $*" >&2
  exit 1
}

require_command() {
  local command_name="$1"
  command -v "$command_name" >/dev/null 2>&1 || die "required command not found: $command_name"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tag)
      [[ $# -ge 2 ]] || die "--tag requires a value"
      tag="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

require_command gh
require_command python3

if [[ -z "$tag" ]]; then
  if ! tag="$(gh release list --repo "$repo" --exclude-drafts --exclude-pre-releases --limit 1 --json tagName --jq '.[0].tagName')"; then
    die "failed to query releases with gh; ensure gh is authenticated and can access $repo"
  fi

  [[ -n "$tag" && "$tag" != "null" ]] || die "no published non-draft non-prerelease release found for $repo"
fi

if ! release_assets_json="$(gh release view "$tag" --repo "$repo" --json assets,tagName)"; then
  die "failed to inspect release $tag with gh; ensure gh is authenticated and the tag exists"
fi

archive_name="gfa_${tag}.tar.gz"
expected_assets=(
  "$archive_name"
  "SHA256SUMS"
)

declare -A release_asset_urls=()
while IFS=$'\t' read -r asset_name asset_url; do
  [[ -n "$asset_name" ]] || continue
  release_asset_urls["$asset_name"]="$asset_url"
done < <(
  RELEASE_ASSETS_JSON="$release_assets_json" python3 - <<'PY'
import json
import os

for asset in json.loads(os.environ["RELEASE_ASSETS_JSON"])["assets"]:
    print(f"{asset['name']}\t{asset['url']}")
PY
)

for asset_name in "${expected_assets[@]}"; do
  [[ -n "${release_asset_urls[$asset_name]:-}" ]] || die "release $tag is missing required asset: $asset_name"
done

tmpdir="$(mktemp -d)"
cleanup() {
  rm -rf "$tmpdir"
}
trap cleanup EXIT

if ! gh release download "$tag" --repo "$repo" --pattern SHA256SUMS --output - >"$tmpdir/SHA256SUMS"; then
  die "failed to download SHA256SUMS from release $tag"
fi

declare -A checksums=()
while read -r checksum asset_name; do
  [[ -n "$checksum" && -n "$asset_name" ]] || continue
  checksums["$asset_name"]="$checksum"
done < "$tmpdir/SHA256SUMS"

[[ -n "${checksums[$archive_name]:-}" ]] || die "SHA256SUMS from release $tag is missing checksum for $archive_name"

version="${tag#v}"
archive_url="${release_asset_urls[$archive_name]}"
archive_sha="${checksums[$archive_name]}"

cat <<EOF
# typed: false
# frozen_string_literal: true

# This file was generated by $script_name. DO NOT EDIT.
class Gfa < Formula
  desc "Git Fetch All CLI for scanning and updating repos in bulk"
  homepage "https://github.com/kwo/gfa"
  url "$archive_url"
  sha256 "$archive_sha"
  version "$version"
  depends_on "node"

  def install
    bin.install "gfa"
  end
end
EOF
